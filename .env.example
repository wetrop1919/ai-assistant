# ============================================
# OLLAMA КОНФИГУРАЦИЯ
# ============================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:8b
OLLAMA_CODE_MODEL=codellama:13b
OLLAMA_FAST_MODEL=phi3:mini
OLLAMA_TIMEOUT=120
OLLAMA_TEMPERATURE_GENERAL=0.7
OLLAMA_TEMPERATURE_CODE=0.2

# ============================================
# RAG И ПАМЯТЬ
# ============================================
# RAG система
RAG_DB_PATH=rag_db
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=5

# Память
MEMORY_DB=memory.db
SHORT_TERM_MEMORY_SIZE=20
MEMORY_EMBEDDING_MODEL=ru_embedding

# ============================================
# РЕЧЕВЫЕ НАСТРОЙКИ
# ============================================
WAKE_WORDS=ассистент,слушай,компьютер
WAKE_WORD_CONFIDENCE=0.90

# Speech-to-Text
WHISPER_MODEL=medium
WHISPER_LANGUAGE=ru
WHISPER_DEVICE=cpu

# Text-to-Speech
TTS_ENGINE=pyttsx3
TTS_LANGUAGE=ru
TTS_VOICE_RATE=150
TTS_VOLUME=1.0

# ============================================
# РЕЖИМЫ РАБОТЫ
# ============================================
CLI_MODE=false
VOICE_MODE=true
SANDBOX_MODE=true

# ============================================
# ЛОГИРОВАНИЕ
# ============================================
LOG_LEVEL=INFO
LOG_FILE=assistant.log
LOG_FORMAT=detailed

# ============================================
# МОНИТОРИНГ
# ============================================
ENABLE_PROMETHEUS=false
PROMETHEUS_PORT=8000
HEALTH_CHECK_INTERVAL=60

# ============================================
# ПРОЧЕЕ
# ============================================
PROJECT_VERSION=0.1.6
PROJECT_NAME=AI Assistant
DEBUG=false

# ============================================
# ИНТЕГРАЦИИ
# ============================================

# Calendar
CALENDAR_ENABLED=false
GOOGLE_CALENDAR_KEY=

# Email
EMAIL_ENABLED=false
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
EMAIL_ADDRESS=mef7608084@gmail.com
EMAIL_PASSWORD=Sedas123@$^

# Todo
TODO_ENABLED=false
TODOIST_TOKEN=

# Smart Home
SMART_HOME_ENABLED=false
HOME_ASSISTANT_URL=http://localhost:8123
HOME_ASSISTANT_TOKEN=
MQTT_BROKER=localhost:1883

# Media
MEDIA_ENABLED=false
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Notifications
NOTIFIER_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK=
DISCORD_WEBHOOK=

SECURITY_SANDBOX_ENABLED=true
SECURITY_SANDBOX_LEVEL=auto
SECURITY_CODE_EXECUTION=sandbox
SECURITY_NETWORK_ACCESS=whitelist
SECURITY_FILE_ACCESS=workspace_only
SECURITY_REQUIRE_CONFIRMATION=["DANGEROUS", "CRITICAL"]